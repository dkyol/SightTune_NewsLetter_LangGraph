# OpenAI
OPENAI_API_KEY=your_openai_key_here
OPENAI_CHAT_MODEL=gpt-4o-mini

# Search tools
SERP_API=your_serpapi_key_here
TAVILY_API=your_tavily_key_here

# Email (Gmail SMTP)
GMAIL_USER=your@email.com
GMAIL_APP_PASSWORD=your_16char_app_password_here   # Google Account → Security → App Passwords

# Google Sheets (subscriber list)
GOOGLE_SHEET_ID=your_sheet_id_from_url_here
GOOGLE_CREDENTIALS='{"type":"service_account","project_id":"..."}'  # full service account JSON

# Newsletter config
NEWSLETTER_THEME=piano music technology
SEND_EMAIL=true

# LangSmith tracing (optional)
LANGCHAIN_API_KEY=your_langsmith_key_here
